# =====================================================================
# Avatar4University Downloader — configurazione
# Copiare in `.env` e popolare i valori.
# =====================================================================

# --- API Avatar4University ---
A4U_API_BASE_URL=https://app.avatar4university.org/data-api/api/v1
A4U_API_KEY=__INSERT_YOUR_API_KEY_HERE__

# --- Autenticazione utente (singolo utente, nessun database) ---
AUTH_USERNAME=admin
AUTH_PASSWORD=__CHANGE_ME__
# Generare con: `openssl rand -hex 32` (o equivalente PowerShell)
JWT_SECRET=__GENERATE_A_LONG_RANDOM_STRING__

# --- Runtime ---
NODE_ENV=development
PORT=3000
