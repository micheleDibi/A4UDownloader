# =====================================================================
# A4U Downloader — configurazione
# Copiare in `.env` e popolare i valori.
# =====================================================================

# --- Database a4u (PostgreSQL locale, sola lettura) ---
# Stringa di connessione per node-postgres. La piattaforma a4u usa il formato
# SQLAlchemy (`postgresql+asyncpg://...`): qui togliere il `+asyncpg`.
#   postgresql+asyncpg://a4u:...@localhost:5433/a4u
#   ->  postgres://a4u:...@localhost:5433/a4u
DATABASE_URL=postgres://a4u:a4u_dev_password@localhost:5433/a4u

# --- File (PDF dispense/slide serviti via HTTP da OVH) ---
# Deve combaciare con OVH_PUBLIC_BASE_URL della piattaforma a4u.
MEDIA_BASE_URL=https://progettiersaf.com/media

# --- Organizzazione di cui mostrare i corsi ---
A4U_ORG_NAME=SSML

# --- Database locale delle approvazioni (SQLite) ---
# Percorso del file .db gestito dal downloader (creato al primo avvio).
# Usare un percorso PERSISTENTE che non venga cancellato dai deploy.
APPROVALS_DB_PATH=./data/approvals.db

# --- Autenticazione utente (singolo utente, nessun database) ---
AUTH_USERNAME=admin
AUTH_PASSWORD=__CHANGE_ME__
# Generare con: `openssl rand -hex 32` (o equivalente PowerShell)
JWT_SECRET=__GENERATE_A_LONG_RANDOM_STRING__

# --- Runtime ---
NODE_ENV=development
PORT=3000
